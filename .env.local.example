# Resend - Contact form email
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Who receives contact form submissions (comma-separated for multiple)
RESEND_TO_EMAIL=nextleveltow@icloud.com

# Optional: Override sender. Default: "Next Level Towing <contact@nextleveltow.com>"
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Mapbox token for the service area map
# Get your token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nextleveltow.com

# Optional: Google Analytics 4 (G-XXXXXXXXXX) for page views, events
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Google Ads conversion labels if your marketing team creates them
# NEXT_PUBLIC_GOOGLE_ADS_PHONE_CONVERSION_LABEL=AbCdEfGhIjKlMnOp
# NEXT_PUBLIC_GOOGLE_ADS_FORM_CONVERSION_LABEL=QrStUvWxYz123456
